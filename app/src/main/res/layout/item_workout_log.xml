<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="8dp"

    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"

    app:cardBackgroundColor="#FFFFFF">

    <!-- layout chua noi dung ben trong -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="16dp">

        <!-- DATE -->
        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="26/05/2026"
            android:textSize="13sp"
            android:textStyle="bold"

            android:textColor="#7C4DFF"

            android:layout_marginBottom="10dp"/>

        <!-- EXERCISE -->
        <!-- row exercise -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:gravity="center_vertical">

            <!-- icon -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"

                android:src="@drawable/baseline_fitness_center_24"

                android:tint="#7C4DFF"/>

            <!-- exercise name -->
            <TextView
                android:id="@+id/txtExerciseName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginStart="10dp"

                android:text="Bench Press"
                android:textSize="20sp"
                android:textStyle="bold"

                android:textColor="#212121"/>

        </LinearLayout>

        <!-- MUSCLE GROUP -->
        <TextView
            android:id="@+id/txtMuscleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nguc"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_muscle_badge"

            android:paddingStart="10dp"
            android:paddingEnd="10dp"

            android:paddingTop="4dp"
            android:paddingBottom="4dp"

            android:textColor="#5E35B1"/>

        <!-- WEIGHT + REPS -->
        <TextView
            android:id="@+id/txtWeightReps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="50kg x 12 reps"

            android:textSize="16sp"
            android:textStyle="bold"

            android:textColor="#5E35B1"

            android:layout_marginTop="12dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>